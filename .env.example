# Copy this file to .env and fill in the values for your Raspberry Pi.
# .env is ignored by git.

DB_NAME=max
DB_USER=max
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

TTN_USERNAME=
TTN_PASSWORD=
TTN_CLIENT_ID=bridge-ttn-test
TTN_HOST=eu1.cloud.thethings.network
TTN_PORT=8883
# Optional. Defaults to v3/$TTN_USERNAME/devices/+/up when omitted.
# TTN_TOPIC=v3/your-application@ttn/devices/+/up

MQTTCLI_DASHBOARD_PORT=8090
